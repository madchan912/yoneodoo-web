# ---------------------------------------------------------------------------
# 요너두 웹 — API 베이스 URL (Vite는 VITE_ 접두사만 클라이언트에 노출됩니다)
# ---------------------------------------------------------------------------
# 사용법: 이 파일을 복사해 `.env.local` 로 저장한 뒤 값을 맞추세요.
#         (.env.local 은 git에 올리지 않는 것을 권장합니다.)
#
# 로컬 Spring Boot (기본 포트 8080)
VITE_API_BASE_URL=http://localhost:8080

# 운영 API 예시 (Render 등 실제 주소로 교체)
# VITE_API_BASE_URL=https://yoneodoo-api.onrender.com
